{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "client-in",
      "port": 6437,
      "listen": "0.0.0.0",
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "<VLESS_UUID>"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "grpc",
        "grpcSettings": {
          "serviceName": "grpc",
          "multiMode": false
        },
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "www.tesla.com:443",
          "xver": 0,
          "serverNames": [
            "tesla.com"
          ],
          "privateKey": "<REALITY_PRIVATE_KEY>",
          "shortIds": [
            ""
          ]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ]
}
